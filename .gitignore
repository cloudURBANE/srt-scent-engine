# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Editor / OS
# Ignore everything in .claude EXCEPT the committed, team-shared settings.json
# and the skills CLAUDE.md indexes -- this blanket ignore is what silently
# kept engine-live-verify / wardrobe-completeness-heal out of every clone.
# (settings.local.json and all other .claude contents stay local/ignored.)
/.claude/*
!/.claude/settings.json
!/.claude/skills/
.cursor/
desktop.ini

# Logs
*.log
debug-*.log
ipc_out.txt

# Runtime caches / generated data
.cache/
out/
.black_sun_cache.json
.fragrantica_clearance_cache.json
.fragrantica_chrome_profile/

# Scratch / throwaway investigation scripts (keep these out of the repo)
scratch/

# Windows malformed-path artifacts (e.g. accidental "c:\tmp...")
c*tmp*

# db_audit_export.py generated artifacts (regenerated on demand)
db_export_fragrances.*
db_audit_report.json
audit_runs/
baseline_*.csv
baseline_*.xlsx
baseline_*.audit.json
